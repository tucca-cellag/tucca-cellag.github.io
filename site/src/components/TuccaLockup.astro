---
/**
 * TuccaLockup — the official Tufts · Center for Cellular Agriculture horizontal
 * lockup, linking to the TUCCA institutional site. Theme-aware: ships both
 * official assets and swaps on Starlight's `html[data-theme='dark']` — black+blue
 * in light, the white lockup in dark. One fixed-size box (swapped
 * background-image) so it's pixel-identical in both themes with no layout shift,
 * and only the active theme's image is fetched.
 *
 * Props: width (px; height derived from the 1093×169 ratio), class.
 */
import blkbl from '../assets/tucca/cca-horiz-blkbl.png';
import white from '../assets/tucca/cca-horiz-white.png';

interface Props {
  width?: number;
  class?: string;
}

const { width = 168, class: className } = Astro.props;
const height = Math.round((width * blkbl.height) / blkbl.width);
const style = `--tl-w:${width}px;--tl-h:${height}px;--tl-light:url("${blkbl.src}");--tl-dark:url("${white.src}")`;
---

<a
  class:list={['tl', className]}
  href="https://cellularagriculture.tufts.edu/"
  aria-label="Tufts University Center for Cellular Agriculture"
  style={style}
>
  <span class="tl-mark" aria-hidden="true"></span>
</a>

<style>
  .tl {
    display: inline-block;
    line-height: 0;
    border-radius: 4px;
  }
  .tl-mark {
    display: block;
    width: var(--tl-w);
    height: var(--tl-h);
    background: var(--tl-light) no-repeat center / contain;
  }
  :global([data-theme='dark']) .tl-mark {
    background-image: var(--tl-dark);
  }
  .tl:focus-visible {
    outline: 2px solid var(--tucca-link);
    outline-offset: 3px;
  }
</style>
